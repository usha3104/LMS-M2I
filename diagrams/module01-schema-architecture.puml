@startuml M2I_LMS_Application_Status_SM
!theme plain
hide footbox

title M2I LMS - Application Status State Machine

[*] --> SUBMITTED
SUBMITTED --> UNDER_REVIEW : Review Started
UNDER_REVIEW --> DOCUMENTS_PENDING : Need More Docs
DOCUMENTS_PENDING --> UNDER_REVIEW : Docs Submitted
UNDER_REVIEW --> INTERVIEW_SCHEDULED : Schedule Interview
INTERVIEW_SCHEDULED --> INTERVIEW_COMPLETED : Interview Done
INTERVIEW_COMPLETED --> SELECTED : Selected
INTERVIEW_COMPLETED --> REJECTED : Rejected

SUBMITTED --> REJECTED : Ineligible
UNDER_REVIEW --> REJECTED : Rejected
DOCUMENTS_PENDING --> REJECTED : Rejected
INTERVIEW_SCHEDULED --> REJECTED : Cancelled

SELECTED --> [*]
REJECTED --> [*]

@enduml

