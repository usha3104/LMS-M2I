@startuml M2I_LMS_Auth_Flow
!theme plain
hide footbox

title M2I LMS - Authentication Flow

actor "User" as user
participant "Client" as client
participant "API Gateway" as gateway
participant "Auth Service" as auth
participant "Database" as db
participant "Email/SMS" as notification

== Login Flow ==

user -> client : Enter credentials
client -> gateway : POST /api/v1/auth/login
gateway -> auth : Validate credentials
auth -> db : Check user credentials
db -> auth : User found

alt OTP Required
    auth -> db : Create OTP
    db -> auth : OTP saved
    auth -> notification : Send OTP
    notification -> user : OTP received
    user -> client : Enter OTP
    client -> gateway : POST /api/v1/auth/otp/verify
    gateway -> auth : Verify OTP
    auth -> db : Check OTP validity
    db -> auth : OTP valid
    
    alt 2FA Enabled
        auth -> user : Request 2FA code
        user -> client : Enter 2FA
        client -> gateway : POST /api/v1/auth/2fa/verify
        gateway -> auth : Verify 2FA
        auth -> db : Check 2FA
    end
end

auth -> db : Create session
db -> auth : Session created
auth -> gateway : Return tokens
gateway -> client : Login successful
client -> user : Redirect to dashboard

== Role-Based Routing ==

alt Role = SUPER_ADMIN
    client -> user : Redirect to Super Admin Dashboard
else Role = NETPY_ADMIN
    client -> user : Redirect to NetPy Admin Dashboard
else Role = COLLEGE_ADMIN
    client -> user : Redirect to College Dashboard
else Role = MENTOR
    client -> user : Redirect to Mentor Dashboard
else Role = COMPANY
    client -> user : Redirect to Company Dashboard
else Role = STUDENT
    client -> user : Redirect to Student Dashboard
end

@enduml

@startuml M2I_LMS_Student_Onboarding
!theme plain
hide footbox

title M2I LMS - Student Onboarding Flow

start

:Select Role: Student;

if (Application Path?) then (College-side)
    :College distributes NetPy Form;
    :Student submits to College Admin;
    :College Admin reviews;
    :Forward to NetPy;
else (Direct)
    :Student fills form on Portal;
    :Submit directly to NetPy;
endif

:Submit Application Form;
:Upload Documents;

:Eligibility Check;

if (Eligible?) then (Yes)
    :Document Verification;
    
    if (Documents Verified?) then (Yes)
        :AI-assisted Scoring;
        :Send Interview Invitation;
        :Self-service Scheduling;
        :Conduct Interview;
        
        if (Selected?) then (Yes)
            :Create User Account;
            :Profile Configuration;
            :Assign Batch;
            :Enable Dashboard Access;
            stop
        else (No)
            :Professional Rejection;
            stop
        endif
    else (No)
        :Request Resubmission;
        stop
    endif
else (No)
    :Reject Application;
    stop
endif

@enduml

