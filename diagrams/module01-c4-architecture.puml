' ============================================
' M2I LMS - Module 01: Authentication, Governance & Onboarding
' C4 Architecture - PlantUML Diagrams
' ============================================
' Version: 1.0
' Last Updated: 2026-03-18
' Purpose: C4 Architecture for Authentication, Role-based Governance, and Onboarding Flows
' ============================================

' ============================================
' LEVEL 1: SYSTEM CONTEXT DIAGRAM
' ============================================
@startuml LEVEL1_SYSTEM_CONTEXT
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title [Level 1] System Context - M2I LMS

package "External Entities" {
    actor Student
    actor Mentor
    actor College
    actor Company
    actor Admin <<Platform Admin\n(Super Admin / NetPy Admin)>>
}

package "External Systems" {
    database "Email Service"
    database "SMS Service"
}

package "M2I LMS System" {
    component "Authentication Module" as AuthModule
    component "Onboarding Module" as OnboardingModule
    component "Application Screening Module" as ScreeningModule
    component "Dashboard Module" as DashboardModule
    database "(Database)" as Database
}

Student --> AuthModule : Login/Register
Student --> OnboardingModule : Apply for Program
Mentor --> OnboardingModule : Apply as Mentor
College --> OnboardingModule : Register Institution
Company --> OnboardingModule : Apply
Admin --> AuthModule : Manage Users
Admin --> ScreeningModule : Review Applications

AuthModule --> EmailService : Send OTP
AuthModule --> SMSService : Send OTP
AuthModule --> Database : Store/Retrieve
OnboardingModule --> Database : Store
ScreeningModule --> Database : Store
DashboardModule --> Database : Retrieve User Data

@enduml

' ============================================
' LEVEL 2: CONTAINER DIAGRAM
' ============================================
@startuml LEVEL2_CONTAINER
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title [Level 2] Container Diagram - M2I LMS

package "Frontend Container" {
    component "Web Application\n(React/Next.js)" as WebApp
    component "Mobile App\n(React Native)" as MobileApp
}

package "API Gateway" {
    component "API Gateway\n(Authentication, Rate Limiting)" as APIGateway
}

package "Backend Services" {
    component "Auth Service\n(Login, OTP, 2FA, Sessions)" as AuthService
    component "Onboarding Service\n(Student, Mentor, College)" as OnboardingService
    component "Screening Service\n(Eligibility, Scoring, Interview)" as ScreeningService
    component "Dashboard Service\n(Role-based routing)" as DashboardService
}

package "Data Layer" {
    database "PostgreSQL Database" as DB
    database "Redis Cache\n(Session, OTP)" as Cache
}

package "External Services" {
    component "Email Service" as EmailService
    component "SMS Service" as SMSService
    component "AI Scoring Service" as AIService
}

WebApp --> APIGateway : HTTPS
MobileApp --> APIGateway : HTTPS

APIGateway --> AuthService : Internal
APIGateway --> OnboardingService : Internal
APIGateway --> ScreeningService : Internal
APIGateway --> DashboardService : Internal

AuthService --> Cache : Store Session
AuthService --> DB : Store Data
OnboardingService --> DB : Store Data
ScreeningService --> DB : Store Data
ScreeningService --> AIService : AI Score

AuthService --> EmailService : Send Email
AuthService --> SMSService : Send SMS
OnboardingService --> EmailService : Send Email
ScreeningService --> EmailService : Send Email
ScreeningService --> SMSService : Send SMS

@enduml

' ============================================
' LEVEL 3: AUTH COMPONENTS
' ============================================
@startuml LEVEL3_AUTH_COMPONENTS
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title [Level 3] Component - Auth Service

package "Auth Service Components" {
    component "AuthController\n(Request handling)" as AuthController
    component "LoginHandler\n(Credential validation)" as LoginHandler
    component "OTPManager\n(Generation, Validation)" as OTPManager
    component "SessionManager\n(Token generation, validation)" as SessionManager
    component "2FA Manager\n(TOTP, Backup codes)" as TwoFactorAuth
    component "PasswordManager\n(Hash, Reset)" as PasswordManager
    component "RoleResolver\n(5-tier governance)" as RoleResolver
}

package "Data Layer" {
    component "User Repository" as UserRepo
    component "Session Repository" as SessionRepo
    component "OTP Repository" as OTPRepo
}

AuthController --> LoginHandler : Validate
LoginHandler --> OTPManager : Generate
LoginHandler --> TwoFactorAuth : Check
LoginHandler --> SessionManager : Create
LoginHandler --> RoleResolver : Resolve
LoginHandler --> PasswordManager : Manage

OTPManager --> OTPRepo : Store/Verify
SessionManager --> SessionRepo : Store
LoginHandler --> UserRepo : Query User
RoleResolver --> UserRepo : Query User

@enduml

' ============================================
' LEVEL 3: ONBOARDING COMPONENTS
' ============================================
