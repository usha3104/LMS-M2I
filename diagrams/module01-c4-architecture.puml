!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title [Level 3] Component - Onboarding Service

package "Onboarding Service Components" {
    component "OnboardController" as OnboardController
    component "Student Onboarding\n(Dual path: College-side/Direct)" as StudentOnboard
    component "Mentor Onboarding" as MentorOnboard
    component "College Onboarding" as CollegeOnboard
    component "Company Onboarding" as CompanyOnboard
    component "Batch Assigner\n(College-specific/Open)" as BatchAssigner
    component "Profile Builder" as ProfileBuilder
}

package "Data Layer" {
    component "Student Application Repo" as StudentAppRepo
    component "Mentor Repository" as MentorRepo
    component "College Repository" as CollegeRepo
    component "Batch Repository" as BatchRepo
}

OnboardController --> StudentOnboard : Route
OnboardController --> MentorOnboard : Route
OnboardController --> CollegeOnboard : Route
OnboardController --> CompanyOnboard : Route

StudentOnboard --> ProfileBuilder : Create
StudentOnboard --> BatchAssigner : Assign
StudentOnboard --> StudentAppRepo : Store
MentorOnboard --> MentorRepo : Store
CollegeOnboard --> CollegeRepo : Store
BatchAssigner --> BatchRepo : Query/Update

@enduml

' ============================================
' LEVEL 3: SCREENING COMPONENTS
' ============================================
@startuml LEVEL3_SCREENING_COMPONENTS
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title [Level 3] Component - Screening Service

package "Screening Service Components" {
    component "ScreenController" as ScreenController
    component "Eligibility Checker" as EligibilityCheck
    component "Document Verifier" as DocVerifier
    component "AI Scoring Engine" as AIScorer
    component "Interview Scheduler" as InterviewScheduler
    component "Selection Manager" as SelectionManager
}

package "Data Layer" {
    component "Application Repository" as ApplicationRepo
    component "Interview Repository" as InterviewRepo
}

ScreenController --> EligibilityCheck : Process
ScreenController --> DocVerifier : Process
ScreenController --> AIScorer : Score
ScreenController --> InterviewScheduler : Schedule
ScreenController --> SelectionManager : Decide

EligibilityCheck --> ApplicationRepo : Update
DocVerifier --> ApplicationRepo : Update
AIScorer --> ApplicationRepo : Store Score
InterviewScheduler --> InterviewRepo : Create
SelectionManager --> ApplicationRepo : Update

