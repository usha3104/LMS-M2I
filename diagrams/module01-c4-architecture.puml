' ============================================
' DECISION POINTS
' ============================================
@startuml DECISION_POINTS
!theme plain

title Decision Points Summary

start
:User login attempt;
if (Existing Account?) then (Yes)
    :Proceed to login flow;
else (No)
    :Redirect to onboarding;
endif

:OTP verification;
if (OTP Valid?) then (Yes)
    :Session created;
else (No)
    :Retry/Error;
endif

if (2FA Enabled?) then (Yes)
    :2FA verification;
endif

:Redirect to role-specific dashboard;
stop

@enduml

