' SECURITY CONTROLS
' ============================================
@startuml SECURITY_CONTROLS
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title Security Controls Summary

package "Authentication Security" #LightCoral {
    component "Password Storage\nArgon2/PBKDF2 hashing with salt"
    component "OTP\n6-digit, 5-minute expiry, rate limiting"
    component "Session\nJWT (15 min), Refresh token (7 days)"
    component "2FA\nTOTP (Google Authenticator) + backup codes"
    component "Rate Limiting\nRedis-based, 10 attempts per minute"
}

package "Transport Security" #LightYellow {
    component "TLS 1.3\nCertificate pinning"
    component "HTTPS Only"
}

package "API Security" #LightGreen {
    component "JWT Validation"
    component "RBAC\nRole-based Access Control"
    component "Input Validation"
}

package "Data Security" #LightBlue {
    component "Encryption at Rest"
    component "Encryption in Transit"
    component "Audit Logging"
}

@enduml

