' ============================================
' LEVEL 4: DEPLOYMENT DIAGRAM
' ============================================
@startuml LEVEL4_DEPLOYMENT
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title [Level 4] Deployment - Kubernetes on Cloud

actor Browser
actor Mobile

package "User Devices" {
    node "Web Browser" as BrowserNode
    node "Mobile Device" as MobileNode
}

package "Cloud Infrastructure - AWS/Azure/GCP" {
    component "Application Load Balancer\n(SSL Termination)" as LB
    
    package "Kubernetes Cluster" {
        package "Frontend Pods" {
            component "Web App Pod\n(Replicas: 2+)" as WebPod
            component "Mobile API Pod\n(Replicas: 2+)" as MobileAPI
        }
        
        package "Backend Pods" {
            component "Auth Service Pod\n(Replicas: 2+)" as AuthPod
            component "Onboarding Service Pod\n(Replicas: 2+)" as OnboardPod
            component "Screening Service Pod\n(Replicas: 2+)" as ScreenPod
            component "Dashboard Service Pod\n(Replicas: 2+)" as DashboardPod
        }
    }
    
    package "Data Layer" {
        database "PostgreSQL Primary\n(RDS Multi-AZ)" as DBPrimary
        database "PostgreSQL Replica\n(Read Replica)" as DBReplica
        database "Redis Cluster\n(ElastiCache)" as RedisCluster
    }
    
    package "External Services" {
        component "Email Service\n(SendGrid SES)" as EmailSvc
        component "SMS Service\n(Twilio SNS)" as SMSSvc
        component "AI Service\n(Lambda/Cloud Function)" as AISvc
    }
}

BrowserNode --> LB : HTTPS
MobileNode --> LB : HTTPS
LB --> WebPod : Route
LB --> MobileAPI : Route

WebPod --> AuthPod : HTTP
WebPod --> OnboardPod : HTTP
WebPod --> ScreenPod : HTTP

AuthPod --> RedisCluster : TCP
AuthPod --> DBPrimary : TCP
OnboardPod --> DBPrimary : TCP
ScreenPod --> DBPrimary : TCP

DBPrimary --> DBReplica : Replication

AuthPod --> EmailSvc : API
AuthPod --> SMSSvc : API
ScreenPod --> AISvc : API

@enduml

' ============================================
' SEQUENCE: AUTHENTICATION FLOW
' ============================================
@startuml SEQ_AUTHENTICATION
!theme plain

title Sequence: Authentication Flow

actor User
participant "Client (Web/Mobile)" as Client
participant "Auth Service" as Auth
participant "Redis (OTP Cache)" as Redis
participant "Database" as DB
participant "Email/SMS Service" as External

User -> Client : Enter credentials
Client -> Auth : POST /api/v1/auth/login
Auth -> DB : Validate credentials
DB --> Auth : User data + password hash
Auth -> Auth : Verify password
Auth -> Redis : Store OTP (5-min TTL)
Redis --> Auth : Success
Auth -> External : Send OTP (Email/SMS)
External --> Auth : Sent
Auth --> Client : { requiresOTP: true }

User -> Client : Enter OTP
Client -> Auth : POST /api/v1/auth/otp/verify
Auth -> Redis : Validate OTP
Redis --> Auth : Valid (mark as used)
Auth -> DB : Create session
Auth --> Client : { accessToken, refreshToken, role }

@enduml

' ============================================
' SEQUENCE: STUDENT ONBOARDING FLOW
' ============================================
@startuml SEQ_STUDENT_ONBOARDING
!theme plain

title Sequence: Student Onboarding Flow

|Student|
|Screening Service|
|Onboarding Service|

start
:Select role: Student;
:Choose application path\n(College-side / Direct);
:Submit application form;
:Upload documents\n(Photo, Aadhar, Marksheets);

|Screening Service|
:Eligibility check;
if (Eligible?) then (Yes)
    :Document verification;
    :AI scoring;
    :Schedule interview;
    
    |Student|
    :Technical interview;
    :Behavioral interview;
    
    |Screening Service|
    if (Selected?) then (Yes)
        :Approve application;
        
        |Onboarding Service|
        :Create account;
        :Profile setup;
        :Batch assignment;
        :Dashboard access;
        
        |Student|
        :Access Student Dashboard;
        stop
    else (No)
        :Reject application;
        stop
    endif
else (No)
    :Mark ineligible;
    stop
endif

@enduml

' ============================================
' SEQUENCE: MENTOR ONBOARDING FLOW
' ============================================
@startuml SEQ_MENTOR_ONBOARDING
!theme plain

title Sequence: Mentor Onboarding Flow

|Student|
|Mentor|
|Admin|
|Onboarding Service|

start
:Mentor|
:Select role: Mentor;
:Submit mentor application;
:Enter personal information;
:Add professional experience;
:Add teaching expertise;
:Upload certifications;

|Admin|
:Review mentor application;
:Verify credentials;
if (Verified?) then (Yes)
    :Approve mentor;
    
    |Onboarding Service|
    :Create mentor profile;
    :Grant mentor dashboard access;
    
    |Mentor|
    :Access Mentor Dashboard;
    stop
else (No)
    :Reject application;
    :Send notification;
    stop
endif

@enduml

' ============================================
' SEQUENCE: COLLEGE ONBOARDING FLOW
' ============================================
@startuml SEQ_COLLEGE_ONBOARDING
!theme plain

title Sequence: College Onboarding Flow

|College|
|Admin|
|Onboarding Service|

start
:College|
:Select role: College;
:Submit college application;
:Enter institution details;
:Add admin contact;
:Submit program details;

|Admin|
:Review college application;
if (Approved?) then (Yes)
    :Approve college;
    
    |Onboarding Service|
    :Create college profile;
    :Grant college dashboard access;
    
    |College|
    :Access College Dashboard;
    stop
else (No)
    :Reject application;
    :Send notification;
    stop
endif

@enduml

' ============================================
' ROLE GOVERNANCE: 5-TIER
' ============================================
@startuml ROLE_GOVERNANCE
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title 5-Tier Role Governance

package "Level 1: Platform Admin" #LightCoral {
    component "Super Admin\n(Platform-wide admin)\nFull system access" as SuperAdmin
}

package "Level 2: Regional Admin" #LightSalmon {
    component "NetPy Admin\n(Regional admin)\nManage colleges, applications" as NetPyAdmin
}

package "Level 3: Institution Admin" #PeachPuff {
    component "College Admin\n(Institution admin)\nManage students, mentors" as CollegeAdmin
}

package "Level 4: Educators" #PaleTurquoise {
    component "Mentor\n(Instructor)\nView assigned students" as Mentor
}

package "Level 5: Learners" #PaleGreen {
    component "Student\n(Learner)\nOwn profile, courses" as Student
    component "Company\n(Employer)\nView eligible students" as Company
}

SuperAdmin -down-> NetPyAdmin : Manages
SuperAdmin -down-> CollegeAdmin : Manages
SuperAdmin -down-> Mentor : Manages
SuperAdmin -down-> Student : Manages
SuperAdmin -down-> Company : Manages

NetPyAdmin -down-> CollegeAdmin : Manages
NetPyAdmin -down-> Student : Manages

CollegeAdmin -down-> Student : Manages
CollegeAdmin -down-> Mentor : Manages

Mentor -down-> Student : Views assigned

@enduml

